  "key_architectural_finding": {
    "discovery": "modelRouterUid is a SESSION TOKEN, not a MODEL IDENTIFIER",
    "explanation": "The UUID format modelRouterUid (e.g., 3ff1e703-8706-40e2-99dc-915c12f93091) is generated per-cascade by the backend and used as a session routing token. The actual model identifiers are human-readable strings like 'kimi-k2-6'.",
    "confidence": "HIGH",
    "evidence": [
      "Same model produces different modelRouterUid values across cascades",
      "Client code extracts modelRouterUid from backend response and uses it as requestedModelUid",
      "Protobuf field 12 (GetCascadeTrajectory) returns modelRouterUid per cascade"
    ]
  },
  "routing_mechanism": {
    "flow": [
      "1. User selects model by human-readable name (e.g., 'kimi-k2-6')",
      "2. Client sends StartCascade RPC → receives cascadeId",
      "3. Client sends SendUserCascadeMessage with requestedModelUid='kimi-k2-6'",
      "4. Backend validates model availability and generates modelRouterUid (UUID)",
      "5. Backend returns modelRouterUid in GetCascadeTrajectory response (field 12)",
      "6. Client uses modelRouterUid as session token for subsequent requests in that cascade"
    ],
    "injection_points": {
      "StartCascade": {
        "url": "http://127.0.0.1:{port}/exa.language_server_pb.LanguageServerService/StartCascade",
        "purpose": "Create cascade session",
        "returns": "cascadeId (UUID)"
      },
      "SendUserCascadeMessage": {
        "url": "http://127.0.0.1:{port}/exa.language_server_pb.LanguageServerService/SendUserCascadeMessage",
        "field_1": "metadata (auth, IDE version)",
        "field_2": "items (chat messages)",
        "field_5": "cascadeConfig.requestedModelUid (human-readable model name)",
        "purpose": "Send user message with model selection"
      },
      "AssignModel": {
        "url": "https://eu.windsurf.com/_route/api_server/exa.api_server_pb.ApiServerService/AssignModel",
        "field_1": "metadata",
        "field_2": "modelRouterUid (UUID session token)",
        "field_3": "cascadeId",
        "field_4": "chatMessagePrompt",
        "purpose": "Assign model to cascade (cloud-based)"
      },
      "GetCascadeTrajectory": {
        "url": "http://127.0.0.1:{port}/exa.language_server_pb.LanguageServerService/GetCascadeTrajectory",
        "response_field_12": "modelRouterUid (UUID)",
        "response_field_11": "assignedModelUid (string)",
        "response_field_24": "model_assignment_info",
        "purpose": "Retrieve cascade state and model assignment"
      }
    }
  },
